
NODE_ENV=development
HOST=127.0.0.1
PORT=8787
LOG_LEVEL=info
CORS_ORIGINS=*

ADMIN_API_KEY=

RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120

# ── Network-metadata privacy ──────────────────────────────────────────────
# Defaults assume the service runs behind a Tor onion (scripts/onion.sh):
# no client IP is ever logged and forwarded headers are not trusted.
# Set LOG_IP=true only if you run behind a trusted reverse proxy and accept
# logging client IPs. TRUST_PROXY=true makes Express read X-Forwarded-* (only
# safe behind a proxy you control — never when exposed via Tor).
LOG_IP=false
TRUST_PROXY=false

# Refuse pool withdrawals until the pool holds at least this many deposits, so a
# user can't deanonymize themselves by withdrawing from a near-empty pool.
# 1 = no guard (dev). Production should set a real floor (e.g. 20+).
POOL_MIN_ANONYMITY_SET=1

DATABASE_URL=postgres://postgres:postgres@localhost:5432/soteria

# ── Solana ───────────────────────────────────────────────────────────────
SOLANA_RPC_URL=https://api.devnet.solana.com
SOTERIA_PROGRAM_ID=9HNLpUVFX61pX759oy1vuMMwQaQaGnK9KgMyhTrDrRGs

RELAYER_SECRET_KEY=
AUTHORITY_SECRET_KEY=
